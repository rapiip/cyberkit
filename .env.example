# Public app URL used for metadata, sitemap, and robots.txt.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstash Redis REST URL for optional Cloud Sync, scanner cache, and rate limiting.
# When omitted, CyberKit uses bounded in-memory storage where possible.
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token paired with UPSTASH_REDIS_REST_URL.
UPSTASH_REDIS_REST_TOKEN=

# Trust proxy-provided client IP headers only when your deployment controls
# the proxy chain that sets x-forwarded-for/x-real-ip/cf-connecting-ip.
CYBERKIT_TRUST_PROXY_HEADERS=false

# Optional NVD API key for higher-rate CVE lookups.
NVD_API_KEY=

# Optional SecurityTrails API key for DNS history enrichment.
SECURITYTRAILS_API_KEY=

# Optional AbuseIPDB API key for IP reputation enrichment.
ABUSEIPDB_API_KEY=

# Optional Shodan API key for exposed-service enrichment.
SHODAN_API_KEY=

# Optional VirusTotal API key for IP reputation enrichment.
VIRUSTOTAL_API_KEY=

# Optional URLhaus auth key for malicious URL/IP context.
URLHAUS_AUTH_KEY=

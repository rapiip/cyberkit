# Public app URL used for metadata, sitemap, and robots.txt.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional external TTL storage for scanner cache and rate limiting.
# When omitted, CyberKit uses bounded in-memory storage for local development.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Trust proxy-provided client IP headers only when your deployment controls
# the proxy chain that sets x-forwarded-for/x-real-ip/cf-connecting-ip.
CYBERKIT_TRUST_PROXY_HEADERS=false

# Optional threat intelligence / lookup providers.
NVD_API_KEY=
SECURITYTRAILS_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
URLHAUS_AUTH_KEY=

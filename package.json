{
  "name": "cyberkit-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/clean-next-dev-types.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pretypecheck": "node scripts/clean-next-dev-types.mjs",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:registry": "tsx --test tests/tool-registry.test.ts",
    "verify": "npm run lint && npm test && npm run build && npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "exifr": "^7.1.3",
    "file-type": "^22.0.1",
    "framer-motion": "^12.40.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-syntax-highlighter": "^16.1.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.42",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
